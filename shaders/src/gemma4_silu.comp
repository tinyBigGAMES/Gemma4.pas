#version 450

// Gemma4.pas element-wise SiLU, in-place: dst[i] = x * sigmoid(x)
// (audio conformer feed-forward / lconv activation, hidden_act=silu)
// Dispatch: ceil(count / 256) workgroups.

layout(local_size_x = 256) in;

layout(push_constant) uniform PushConstants {
    uint count;
};

layout(set = 0, binding = 0) buffer DstBuf {
    float dst[];
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= count) return;
    float x = dst[i];
    dst[i] = x / (1.0 + exp(-x));
}
