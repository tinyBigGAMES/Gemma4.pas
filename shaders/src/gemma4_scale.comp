#version 450

// Gemma4.pas scalar scale (in-place)
// Computes: dst[i] *= scale
//
// Dispatch: ceil(count / 256) workgroups

layout(local_size_x = 256) in;

layout(push_constant) uniform PushConstants {
    uint count;
    float scale;
};

layout(set = 0, binding = 0) buffer DstBuf {
    float dst[];
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= count) return;
    dst[i] *= scale;
}
